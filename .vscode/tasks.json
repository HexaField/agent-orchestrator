{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:cli-and-run-e2e",
      "type": "shell",
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "command": "npm run build --silent && npx vitest run tests/e2e/ollama-20b.spec.ts --run",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "run single e2e test (codex-ollama-large)",
      "type": "shell",
      "command": "npx vitest run tests/e2e/codex-ollama-large-context.spec.ts --run",
      "isBackground": false,
      "problemMatcher": ["$vitest"]
    }
  ]
}
