{
  "compilerOptions": {
    "target": "ES2022",
  "module": "CommonJS",
  "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src", "tests", "bin"]
}
