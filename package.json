{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "description": "Spec-driven coding-agent orchestrator CLI with TDD and audit artifacts",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-orchestrator": "bin/agent-orchestrator"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --dts --clean",
    "postbuild": "chmod +x ./bin/agent-orchestrator || true",
    "lint": "eslint . --ext .ts --max-warnings=20",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build --silent && vitest run --exclude \"tests/e2e/**\"",
    "e2e:codex-ollama-large": "npm run build --silent && vitest run tests/e2e/codex-ollama-large-context.spec.ts --testTimeout=900000",
    "test:watch": "vitest",
    "e2e": "npm run build --silent && vitest run tests/e2e --testTimeout=900000",
    "format": "prettier -w .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0",
    "marked": "^12.0.2",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
