{
  "args": [
    "exec",
    "--model",
    "gpt-oss:20b",
    "--json",
    "-c",
    "model_provider=ollama",
    "-c",
    "model_providers.ollama.name=Ollama",
    "-c",
    "model_providers.ollama.base_url=http://localhost:11434/v1",
    "--oss",
    "Implement the spec."
  ],
  "env": {
    "OPENAI_API_BASE": "http://localhost:11434/v1",
    "CODEX_API_BASE": "http://localhost:11434/v1",
  "DEBUG_CODEX": "1",
  "ALLOW_COMMANDS": "1",
    "PATH": "<REPO_ROOT>/node_modules/.bin:/usr/local/bin:/usr/bin:/bin",
    "HOME": "<E2E_HOME>",
    "model": "gpt-oss:20b"
  }
}
